generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String        @id @default(uuid())
  name         String
  email        String        @unique
  phone        String?
  role         Role          @default(CLIENT)
  password     String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[] @relation("UserAppointments")
  company      Company?      @relation("CompanyOwner")
  leads        Lead[]        @relation("UserLeads")
  cpf             String?        @unique
  address         String?
  addresses       Address[]
  paymentMethods  PaymentMethod[]
}

model Company {
  id        String     @id @default(uuid())
  ownerId   String     @unique
  name      String
  niche     String
  email     String?
  whatsapp  String?
  instagram String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  owner     User       @relation("CompanyOwner", fields: [ownerId], references: [id])
  employees Employee[]
  leads     Lead[]
  products  Product[]
  services  Service[]
  locations Location[]
  blocks    Block[]
  cnpj      String?    @unique
  legalName String?
  imageUrl  String?
  appointments Appointment[]
}

model Location {
  id           String        @id @default(uuid())
  companyId    String
  name         String
  cep          String
  address      String
  number       String
  neighborhood String
  city         String
  state        String
  mapsLink     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id])
  appointments Appointment[]
  employees    Employee[]
}

model Employee {
  id           String        @id @default(uuid())
  companyId    String
  locationId   String?
  name         String
  role         String?
  image        String?
  hours        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  company      Company       @relation(fields: [companyId], references: [id])
  location     Location?     @relation(fields: [locationId], references: [id])
  blocks       Block[]
}

model Service {
  id           String        @id @default(uuid())
  companyId    String
  name         String
  description  String?
  price        Float
  promoPrice   Float?
  duration     Int
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  company      Company       @relation(fields: [companyId], references: [id])
  appointments Appointment[]
}

model Product {
  id          String   @id @default(uuid())
  companyId   String
  name        String
  description String?
  price       Float
  stock       Int      @default(0)
  image       String?
  delivery    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  company     Company  @relation(fields: [companyId], references: [id])
}

model Lead {
  id        String   @id @default(uuid())
  companyId String
  userId    String?
  name      String
  phone     String
  email     String?
  address   String?
  interest  String
  converted Boolean  @default(false)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  company   Company  @relation(fields: [companyId], references: [id])
  user      User?    @relation("UserLeads", fields: [userId], references: [id])
}

model Appointment {
  id         String            @id @default(uuid())
  employeeId String
  serviceId  String
  locationId String
  companyId  String
  userId     String
  date       DateTime
  status     AppointmentStatus @default(PENDING)
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  employee   Employee          @relation(fields: [employeeId], references: [id])
  service    Service           @relation(fields: [serviceId], references: [id])
  location   Location          @relation(fields: [locationId], references: [id])
  company    Company           @relation(fields: [companyId], references: [id])
  user       User              @relation("UserAppointments", fields: [userId], references: [id])
}

model AuditLog {
  id        String   @id @default(uuid())
  userId    String?
  query     String
  params    String?
  timestamp DateTime @default(now())
}

enum Role {
  CLIENT
  BUSINESS
}

enum AppointmentStatus {
  PENDING
  CONFIRMED
  CANCELLED
  COMPLETED
}

model Address {
  id           String   @id @default(uuid())
  userId       String
  cep          String
  street       String
  number       String
  complement   String?
  neighborhood String
  city         String
  state        String
  isDefault    Boolean  @default(false)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model PaymentMethod {
  id         String   @id @default(uuid())
  userId     String
  cardName   String
  lastDigits String
  brand      String
  expiry     String
  isFavorite Boolean  @default(false)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user         User     @relation(fields: [userId], references: [id])
}

model Block {
  id         String   @id @default(uuid())
  companyId  String
  employeeId String?
  date       DateTime
  reason     String?
  situation  String   @default("Feriado")
  openTime   String?
  closeTime  String?
  isAllDay   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  company    Company  @relation(fields: [companyId], references: [id])
  employee   Employee? @relation(fields: [employeeId], references: [id])
}
